import requests
import json
import os

BOT_TOKEN = "8770078207:AAEx81u3m75I2p69QStnem78L6LMSVQZNpY"
CHAT_ID = "819994547"

def send(msg):
    try:
        url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
        requests.get(url, params={"chat_id": CHAT_ID, "text": msg})
    except:
        pass

# 🔥 Track alerted stocks (duplicate avoid)
FILE = "alerted.json"

if os.path.exists(FILE):
    with open(FILE, "r") as f:
        alerted = json.load(f)
else:
    alerted = {}

stocks = [
"RELIANCE","TCS","INFY","HDFCBANK","ICICIBANK","SBIN","ITC",
"AXISBANK","KOTAKBANK","LT","BHARTIARTL","MARUTI",
"TATAMOTORS","ADANIPORTS","ADANIENT","JSWSTEEL"
]

signals = []

for stock in stocks:
    try:
        url = f"https://priceapi.moneycontrol.com/pricefeed/nse/equitycash/{stock}"
        res = requests.get(url)

        if res.status_code != 200:
            continue

        data = res.json()

        if "data" not in data or data["data"] is None:
            continue

        d = data["data"]

        price = float(d.get("pricecurrent", 0) or 0)
        open_price = float(d.get("open", 0) or 0)
        high = float(d.get("high", 0) or 0)
        low = float(d.get("low", 0) or 0)

        if price == 0 or open_price == 0 or high == 0:
            continue

        # 🔥 Weak open (open ≈ high)
        if abs(open_price - high) / high < 0.002:

            # 🔥 Price falling
            if price < open_price:

                # 🔥 Avoid duplicate alert
                if stock in alerted:
                    continue

                entry = low
                sl = high
                target = low - (high - low)

                move_strength = (open_price - price) / open_price

                signals.append((stock, entry, sl, target, move_strength))

                alerted[stock] = True

    except:
        continue

# 🔥 Sort strongest moves
signals = sorted(signals, key=lambda x: x[4], reverse=True)[:3]

# 🔥 Telegram message
msg = "🔥 TOP SHORT SETUPS:\n\n"

for stock, entry, sl, target, strength in signals:
    msg += (
        f"🔻 {stock}\n"
        f"Entry: {entry}\n"
        f"SL: {sl}\n"
        f"Target: {target}\n\n"
    )

if signals:
    send(msg)

# Save alerted list
with open(FILE, "w") as f:
    json.dump(alerted, f)

print("✅ Pro Scanner Done")
